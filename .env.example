# Copier ce fichier en .env et remplir les valeurs

# Serveur
PORT=3000
BASE_URL=http://localhost:3000
NODE_ENV=development

# JWT — générer avec :
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=changez-moi-en-production

# SMTP (ex : Gmail avec mot de passe d'application, Brevo, Mailgun…)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre@email.com
SMTP_PASS=votre-mot-de-passe-app
SMTP_FROM=zrevents06 <votre@email.com>

# Discord Bot (optionnel — logs vers Discord)
DISCORD_BOT_URL=http://localhost:3001
DISCORD_API_KEY=

# Stripe (mode test : utiliser les clés pk_test_ / sk_test_ de dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Récupérer STRIPE_WEBHOOK_SECRET avec : stripe listen --forward-to localhost:3000/api/webhooks/stripe
